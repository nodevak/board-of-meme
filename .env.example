# ─────────────────────────────────────────────
# Board of Meme – Environment Variables
# Copy this file to .env.local for local dev
# Set these as Railway env vars in production
# ─────────────────────────────────────────────

# Neon Database (get from neon.tech → your project → Connection String)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Helius RPC (get from helius.dev → API Keys)
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Your SPL Token Mint Address (the contract address of your coin)
NEXT_PUBLIC_TOKEN_MINT=YOUR_TOKEN_MINT_ADDRESS_HERE

# Token name shown in the UI
NEXT_PUBLIC_TOKEN_NAME=YOUR_TOKEN

# Minimum tokens required to post (set 0 to allow any holder)
NEXT_PUBLIC_MIN_TOKENS=1

# Solana network: mainnet-beta | devnet
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
